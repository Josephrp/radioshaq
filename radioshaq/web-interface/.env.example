# RadioShaq Web Interface – environment variables
# Copy to .env and set values. Restart the dev server (npm run dev) after changing.

# API base URL (default: http://localhost:8000)
# VITE_RADIOSHAQ_API=http://localhost:8000

# Auth token is acquired at runtime (POST /auth/token) and applied with setApiToken(...)
# Optional: Bearer token for authenticated API calls
# VITE_RADIOSHAQ_TOKEN=

# Optional: Google Maps JavaScript API key (for Map page, Radio field map, Transcripts "View on map")
# Get a key at https://console.cloud.google.com/apis/credentials → Create credentials → API key
# Enable "Maps JavaScript API" in APIs & Services → Library. Restrict the key by HTTP referrer (e.g. http://localhost:3000/*).
# VITE_GOOGLE_MAPS_API_KEY=
