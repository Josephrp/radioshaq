# Database (PostgreSQL) – used by Alembic migrations and the app
# Option A: set a full URL (sync URL for migrations; asyncpg for app)
# DATABASE_URL=postgresql://user:password@localhost:5432/radioshaq

# Option B: set individual params (defaults shown – use for local testing)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=radioshaq
POSTGRES_USER=radioshaq
POSTGRES_PASSWORD=radioshaq

# If you updated Postgres username/password, set the new values above or in DATABASE_URL.
# Copy this file to .env and adjust: cp .env.example .env
