# =============================================================================
# RadioShaq – exhaustive environment variable reference
# =============================================================================
# Copy to .env and set values. All RADIOSHAQ_* options can also be set in
# config.yaml; env overrides file. See docs/configuration.md for full reference.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL) – used by app and Alembic migrations
# -----------------------------------------------------------------------------
# Option A: full URL (app uses asyncpg; Alembic uses sync – +asyncpg stripped)
# DATABASE_URL=postgresql://user:password@localhost:5434/radioshaq

# Option B: individual params (Alembic builds URL from these)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434
POSTGRES_DB=radioshaq
POSTGRES_USER=radioshaq
POSTGRES_PASSWORD=radioshaq

# App uses RADIOSHAQ_DATABASE__POSTGRES_URL if set; else builds from above or default
# RADIOSHAQ_DATABASE__POSTGRES_URL=postgresql+asyncpg://radioshaq:radioshaq@127.0.0.1:5434/radioshaq
# RADIOSHAQ_DATABASE__POSTGRES_POOL_SIZE=10
# RADIOSHAQ_DATABASE__POSTGRES_MAX_OVERFLOW=20
# RADIOSHAQ_DATABASE__POSTGRES_ECHO=false
# RADIOSHAQ_DATABASE__DYNAMODB_TABLE_PREFIX=radioshaq
# RADIOSHAQ_DATABASE__DYNAMODB_ENDPOINT=
# RADIOSHAQ_DATABASE__DYNAMODB_REGION=us-east-1
# RADIOSHAQ_DATABASE__REDIS_URL=redis://localhost:6379/0
# RADIOSHAQ_DATABASE__ALEMBIC_CONFIG=infrastructure/local/alembic.ini
# RADIOSHAQ_DATABASE__AUTO_MIGRATE=false

# -----------------------------------------------------------------------------
# Core (mode, debug, paths)
# -----------------------------------------------------------------------------
# RADIOSHAQ_MODE=field
# RADIOSHAQ_DEBUG=false
# RADIOSHAQ_LOG_LEVEL=INFO
# RADIOSHAQ_WORKSPACE_DIR=~/.radioshaq
# RADIOSHAQ_DATA_DIR=~/.radioshaq/data

# -----------------------------------------------------------------------------
# JWT / Auth (set SECRET_KEY in production)
# -----------------------------------------------------------------------------
# RADIOSHAQ_JWT__SECRET_KEY=dev-secret-change-in-production
# RADIOSHAQ_JWT__ALGORITHM=HS256
# RADIOSHAQ_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=30
# RADIOSHAQ_JWT__REFRESH_TOKEN_EXPIRE_DAYS=7
# RADIOSHAQ_JWT__FIELD_TOKEN_EXPIRE_HOURS=24
# RADIOSHAQ_JWT__REQUIRE_STATION_ID=true

# -----------------------------------------------------------------------------
# LLM (set the API key for your provider)
# -----------------------------------------------------------------------------
# RADIOSHAQ_LLM__PROVIDER=mistral
# RADIOSHAQ_LLM__MODEL=mistral-large-latest
# RADIOSHAQ_LLM__MISTRAL_API_KEY=
# RADIOSHAQ_LLM__OPENAI_API_KEY=
# RADIOSHAQ_LLM__ANTHROPIC_API_KEY=
# RADIOSHAQ_LLM__CUSTOM_API_BASE=
# RADIOSHAQ_LLM__CUSTOM_API_KEY=
# RADIOSHAQ_LLM__TEMPERATURE=0.1
# RADIOSHAQ_LLM__MAX_TOKENS=4096
# RADIOSHAQ_LLM__TIMEOUT_SECONDS=60.0
# RADIOSHAQ_LLM__MAX_RETRIES=3
# RADIOSHAQ_LLM__RETRY_DELAY_SECONDS=1.0
# Alternative: some code also reads MISTRAL_API_KEY / OPENAI_API_KEY directly
# MISTRAL_API_KEY=
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Memory (per-callsign memory, Hindsight, daily summaries)
# -----------------------------------------------------------------------------
# RADIOSHAQ_MEMORY__ENABLED=true
# RADIOSHAQ_MEMORY__HINDSIGHT_BASE_URL=http://localhost:8888
# RADIOSHAQ_MEMORY__HINDSIGHT_ENABLED=true
# RADIOSHAQ_MEMORY__RECENT_MESSAGES_LIMIT=40
# RADIOSHAQ_MEMORY__DAILY_SUMMARY_DAYS=7
# RADIOSHAQ_MEMORY__SUMMARY_TIMEZONE=America/New_York

# -----------------------------------------------------------------------------
# Radio (CAT, FLDIGI, packet, SDR TX, voice)
# -----------------------------------------------------------------------------
# RADIOSHAQ_RADIO__ENABLED=false
# RADIOSHAQ_RADIO__RIG_MODEL=1
# RADIOSHAQ_RADIO__PORT=/dev/ttyUSB0
# RADIOSHAQ_RADIO__BAUDRATE=9600
# RADIOSHAQ_RADIO__USE_DAEMON=false
# RADIOSHAQ_RADIO__DAEMON_HOST=localhost
# RADIOSHAQ_RADIO__DAEMON_PORT=4532
# RADIOSHAQ_RADIO__FLDIGI_HOST=localhost
# RADIOSHAQ_RADIO__FLDIGI_PORT=7362
# RADIOSHAQ_RADIO__FLDIGI_ENABLED=false
# RADIOSHAQ_RADIO__PACKET_ENABLED=false
# RADIOSHAQ_RADIO__PACKET_CALLSIGN=N0CALL
# RADIOSHAQ_RADIO__PACKET_SSID=0
# RADIOSHAQ_RADIO__PACKET_KISS_HOST=localhost
# RADIOSHAQ_RADIO__PACKET_KISS_PORT=8001
# RADIOSHAQ_RADIO__TX_ENABLED=true
# RADIOSHAQ_RADIO__RX_ENABLED=true
# RADIOSHAQ_RADIO__MAX_POWER_WATTS=100.0
# RADIOSHAQ_RADIO__AUDIO_OUTPUT_DEVICE=
# RADIOSHAQ_RADIO__VOICE_USE_TTS=false
# RADIOSHAQ_RADIO__TX_AUDIT_LOG_PATH=
# RADIOSHAQ_RADIO__TX_ALLOWED_BANDS_ONLY=true
# Compliance: region/country for restricted bands and band plan (see docs/compliance-regulatory.md)
# RADIOSHAQ_RADIO__RESTRICTED_BANDS_REGION=FCC   # US=FCC, Canada=CA, EU/UK=CEPT|FR|UK|ES, Australia=AU, South Africa=ZA, NZ|JP|IN, or country code (e.g. AR, MX, NG)
# RADIOSHAQ_RADIO__BAND_PLAN_REGION=            # Optional override: ITU_R1 (EU/Africa), ITU_R3 (Asia–Pacific), or leave blank to use backend default
# RADIOSHAQ_RADIO__CALLSIGN_REGISTRY_REQUIRED=false
# RADIOSHAQ_RADIO__SDR_TX_ENABLED=false
# RADIOSHAQ_RADIO__SDR_TX_BACKEND=hackrf
# RADIOSHAQ_RADIO__SDR_TX_DEVICE_INDEX=0
# RADIOSHAQ_RADIO__SDR_TX_SERIAL=
# RADIOSHAQ_RADIO__SDR_TX_MAX_GAIN=47
# RADIOSHAQ_RADIO__SDR_TX_ALLOW_BANDS_ONLY=true
# RADIOSHAQ_RADIO__AUDIO_INPUT_ENABLED=false
# RADIOSHAQ_RADIO__AUDIO_OUTPUT_ENABLED=false
# RADIOSHAQ_RADIO__AUDIO_MONITORING_ENABLED=false
# allowed_callsigns: use config.yaml (list) or JSON in env, e.g. RADIOSHAQ_RADIO__ALLOWED_CALLSIGNS='["K1ABC","W2XYZ"]'

# -----------------------------------------------------------------------------
# Audio (voice_rx pipeline: VAD, ASR, triggers, response mode)
# Web UI shows VAD/metrics; when no live signal, a placeholder message is shown
# until the pipeline feeds metrics via WebSocket.
# -----------------------------------------------------------------------------
# RADIOSHAQ_AUDIO__INPUT_DEVICE=
# RADIOSHAQ_AUDIO__INPUT_SAMPLE_RATE=16000
# RADIOSHAQ_AUDIO__OUTPUT_DEVICE=
# RADIOSHAQ_AUDIO__PREPROCESSING_ENABLED=true
# RADIOSHAQ_AUDIO__AGC_ENABLED=true
# RADIOSHAQ_AUDIO__AGC_TARGET_RMS=0.1
# RADIOSHAQ_AUDIO__HIGHPASS_FILTER_ENABLED=true
# RADIOSHAQ_AUDIO__HIGHPASS_CUTOFF_HZ=80.0
# RADIOSHAQ_AUDIO__DENOISING_ENABLED=true
# RADIOSHAQ_AUDIO__DENOISING_BACKEND=rnnoise
# RADIOSHAQ_AUDIO__NOISE_CALIBRATION_SECONDS=3.0
# RADIOSHAQ_AUDIO__MIN_SNR_DB=3.0
# RADIOSHAQ_AUDIO__VAD_ENABLED=true
# RADIOSHAQ_AUDIO__VAD_THRESHOLD=0.02
# RADIOSHAQ_AUDIO__VAD_MODE=aggressive
# RADIOSHAQ_AUDIO__PRE_SPEECH_BUFFER_MS=300
# RADIOSHAQ_AUDIO__POST_SPEECH_BUFFER_MS=400
# RADIOSHAQ_AUDIO__MIN_SPEECH_DURATION_MS=500
# RADIOSHAQ_AUDIO__MAX_SPEECH_DURATION_MS=30000
# RADIOSHAQ_AUDIO__SILENCE_DURATION_MS=800
# RADIOSHAQ_AUDIO__ASR_MODEL=voxtral
# RADIOSHAQ_AUDIO__ASR_LANGUAGE=en   # en | fr | es | auto (auto = detect language)
# RADIOSHAQ_AUDIO__ASR_MIN_CONFIDENCE=0.6
# RADIOSHAQ_AUDIO__RESPONSE_MODE=listen_only
# RADIOSHAQ_AUDIO__RESPONSE_TIMEOUT_SECONDS=30.0
# RADIOSHAQ_AUDIO__RESPONSE_DELAY_MS=500
# RADIOSHAQ_AUDIO__RESPONSE_COOLDOWN_SECONDS=5.0
# RADIOSHAQ_AUDIO__TRIGGER_ENABLED=true
# RADIOSHAQ_AUDIO__TRIGGER_MATCH_MODE=contains
# RADIOSHAQ_AUDIO__TRIGGER_CALLSIGN=
# RADIOSHAQ_AUDIO__TRIGGER_MIN_CONFIDENCE=0.7
# RADIOSHAQ_AUDIO__AUDIO_ACTIVATION_ENABLED=false
# RADIOSHAQ_AUDIO__AUDIO_ACTIVATION_PHRASE=radioshaq
# RADIOSHAQ_AUDIO__AUDIO_ACTIVATION_MODE=session
# RADIOSHAQ_AUDIO__PTT_COORDINATION_ENABLED=true
# RADIOSHAQ_AUDIO__PTT_COOLDOWN_MS=500
# RADIOSHAQ_AUDIO__BREAK_IN_ENABLED=true
# trigger_phrases: use config.yaml (list) or JSON, e.g. RADIOSHAQ_AUDIO__TRIGGER_PHRASES='["radioshaq","field station"]'

# -----------------------------------------------------------------------------
# Field mode (when RADIOSHAQ_MODE=field)
# -----------------------------------------------------------------------------
# RADIOSHAQ_FIELD__STATION_ID=FIELD-01
# RADIOSHAQ_FIELD__CALLSIGN=
# RADIOSHAQ_FIELD__HQ_BASE_URL=https://hq.radioshaq.example.com
# RADIOSHAQ_FIELD__HQ_WS_URL=
# RADIOSHAQ_FIELD__HQ_AUTH_TOKEN=
# RADIOSHAQ_FIELD__SYNC_INTERVAL_SECONDS=60
# RADIOSHAQ_FIELD__SYNC_BATCH_SIZE=100
# RADIOSHAQ_FIELD__SYNC_MAX_RETRIES=5
# RADIOSHAQ_FIELD__SYNC_RETRY_DELAY=10
# RADIOSHAQ_FIELD__SYNC_ON_CONNECT=true
# RADIOSHAQ_FIELD__OFFLINE_MODE=false
# RADIOSHAQ_FIELD__MAX_OFFLINE_QUEUE_SIZE=1000

# -----------------------------------------------------------------------------
# HQ mode (when RADIOSHAQ_MODE=hq)
# -----------------------------------------------------------------------------
# RADIOSHAQ_HQ__HOST=0.0.0.0
# RADIOSHAQ_HQ__PORT=8000
# RADIOSHAQ_HQ__WS_ENABLED=true
# RADIOSHAQ_HQ__WS_PATH=/ws
# RADIOSHAQ_HQ__MAX_FIELD_STATIONS=100
# RADIOSHAQ_HQ__FIELD_AUTH_REQUIRED=true
# RADIOSHAQ_HQ__FIELD_REGISTRATION_OPEN=false
# RADIOSHAQ_HQ__AUTO_COORDINATION_ENABLED=true
# RADIOSHAQ_HQ__COORDINATION_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# PM2 (process manager)
# -----------------------------------------------------------------------------
# RADIOSHAQ_PM2__INSTANCES=1
# RADIOSHAQ_PM2__AUTORESTART=true
# RADIOSHAQ_PM2__WATCH=true
# RADIOSHAQ_PM2__MAX_MEMORY_RESTART=1G
# RADIOSHAQ_PM2__LOG_DIR=logs
# RADIOSHAQ_PM2__LOG_DATE_FORMAT=YYYY-MM-DD HH:mm:ss Z
# RADIOSHAQ_PM2__MERGE_LOGS=false
# RADIOSHAQ_PM2__ENV_FILE=.env
# RADIOSHAQ_PM2__SOURCE_MAP_SUPPORT=true

# -----------------------------------------------------------------------------
# Runtime / server (not in Pydantic schema; used by server or CLI)
# -----------------------------------------------------------------------------
# Enable MessageBus consumer in API (push work into REACT loop)
# RADIOSHAQ_BUS_CONSUMER_ENABLED=0
# API bind (server uses these when starting uvicorn)
# API_HOST=0.0.0.0
# API_PORT=8000
# RADIOSHAQ_API_HOST=0.0.0.0
# RADIOSHAQ_API_PORT=8000
# RELOAD=false
# CLI base URL and token for scripts
# RADIOSHAQ_API=http://localhost:8000
# RADIOSHAQ_TOKEN=
# TTS (ElevenLabs) – used when voice_use_tts is true
# ELEVENLABS_API_KEY=
